{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "🤖 AI Anomaly Detection",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "title": "Anomaly Score per Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          },
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.7 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "container_anomaly_score",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Anomaly Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.7 }
            ]
          },
          "mappings": [],
          "unit": "short",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "container_anomaly_score",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "row",
      "title": "🐳 Container CPU Usage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },

    {
      "id": 5,
      "title": "CPU Usage per Container (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "percent",
          "min": 0
        }
      },
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[2m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "Top CPU Containers",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "topk(5, rate(container_cpu_usage_seconds_total{name!=\"\"}[2m]) * 100)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "row",
      "title": "💾 Container Memory Usage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },

    {
      "id": 8,
      "title": "Memory Usage per Container (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "decmbytes",
          "min": 0
        }
      },
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name!=\"\"} / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "title": "Memory Usage % of Limit",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(container_memory_usage_bytes{name!=\"\"} / container_spec_memory_limit_bytes{name!=\"\"}) * 100 > 0",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "🌐 Network I/O",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },

    {
      "id": 11,
      "title": "Network Receive (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "Bps"
        }
      },
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name!=\"\"}[2m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "title": "Network Transmit (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "Bps"
        }
      },
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name!=\"\"}[2m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 13,
      "type": "row",
      "title": "🖥️ Host System Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false
    },

    {
      "id": 14,
      "title": "Host CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 15,
      "title": "Host Memory Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 16,
      "title": "Host Disk Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "ffgbz92vu7bi8b" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["containers", "anomaly", "AI"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI Container Health Monitor",
  "uid": "ai-container-health",
  "version": 1
}